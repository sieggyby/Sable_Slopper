# Sable environment — copy to /opt/sable/.env and fill in values
# Never commit the real .env file

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
SOCIALDATA_API_KEY=sd_...

# --- Optional (enable features) ---
REPLICATE_API_TOKEN=r8_...
ELEVENLABS_API_KEY=...

# --- Postgres (Phase 3) ---
# When migrated, set this to switch sable.db from SQLite to Postgres.
# Leave commented to keep using SQLite.
# SABLE_DB_URL=postgresql://sable:changeme@localhost:5432/sable

# --- Paths (defaults shown, override if needed) ---
# SABLE_HOME=/opt/sable/data
# SABLE_WORKSPACE=/opt/sable/workspace
